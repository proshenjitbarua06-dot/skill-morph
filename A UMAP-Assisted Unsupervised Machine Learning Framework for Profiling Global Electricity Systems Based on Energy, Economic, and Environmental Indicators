        "\n",
        "from scipy.stats import kruskal\n",
        "\n",
        "kruskal_results = []\n",
        "\n",
        "for col in numeric_cols:\n",
        "\n",
        "    groups = [group[col].values\n",
        "              for _, group in df_cluster.groupby(\"Cluster\")]\n",
        "\n",
        "    H, p = kruskal(*groups)\n",
        "\n",
        "    kruskal_results.append([col,H,p])\n",
        "\n",
        "kruskal_df = pd.DataFrame(\n",
        "    kruskal_results,\n",
        "    columns=[\"Feature\",\"H-statistic\",\"p-value\"]\n",
        ")\n",
        "\n",
        "kruskal_df = kruskal_df.sort_values(\"p-value\")\n",
