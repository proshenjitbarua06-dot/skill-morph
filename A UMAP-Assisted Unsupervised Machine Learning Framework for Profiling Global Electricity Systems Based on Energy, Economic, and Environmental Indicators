        "# ==========================================\n",
        "# One-way ANOVA\n",
        "# ==========================================\n",
        "\n",
        "from scipy.stats import f_oneway\n",
        "\n",
        "numeric_cols = df_cluster.select_dtypes(include=np.number).columns.drop(\"Cluster\")\n",
        "\n",
        "anova_results = []\n",
        "\n",
        "for col in numeric_cols:\n",
        "\n",
        "    groups = [group[col].values\n",
        "              for _, group in df_cluster.groupby(\"Cluster\")]\n",
        "\n",
        "    F, p = f_oneway(*groups)\n",
        "\n",
        "    anova_results.append([col, F, p])\n",
        "\n",
        "anova_df = pd.DataFrame(\n",
        "    anova_results,\n",
        "    columns=[\"Feature\",\"F-statistic\",\"p-value\"]\n",
        ")\n",
        "\n",
        "anova_df = anova_df.sort_values(\"p-value\")\n",
        "\n",
        "display(anova_df)\n",
        "\n",
        "print(\"\\nSignificant Features (p < 0.05)\\n\")\n",
        "display(anova_df[anova_df[\"p-value\"]<0.05])"
      ],
