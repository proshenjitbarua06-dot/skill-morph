        "# ==========================================\n",
        "# Radar Chart of Cluster Profiles\n",
        "# ==========================================\n",
        "\n",
        "from sklearn.preprocessing import MinMaxScaler\n",
        "import matplotlib.pyplot as plt\n",
        "import numpy as np\n",
        "\n",
        "# Select important indicators\n",
        "features = [\n",
        "    \"GDP_USD_Billion\",\n",
        "    \"Electricity_Consumption_TWh\",\n",
        "    \"Installed_Capacity_GW\",\n",
        "    \"Renewable_Percentage\",\n",
        "    \"CO2_Emissions_MT\",\n",
        "    \"Electricity_Per_Capita_kWh\",\n",
        "    \"Transmission_Distribution_Loss_Pct\",\n",
        "    \"Energy_Intensity_kWh_per_1000USD\"\n",
        "]\n",
        "\n",
        "cluster_profile = df_cluster.groupby(\"Cluster\")[features].mean()\n",
        "\n",
        "# Normalize\n",
        "scaler = MinMaxScaler()\n",
        "profile_scaled = pd.DataFrame(\n",
        "    scaler.fit_transform(cluster_profile),\n",
        "    columns=features,\n",
        "    index=cluster_profile.index\n",
        ")\n",
        "\n",
        "categories = list(profile_scaled.columns)\n",
        "N = len(categories)\n",
        "\n",
        "angles = np.linspace(0, 2*np.pi, N, endpoint=False).tolist()\n",
        "angles += angles[:1]\n",
        "\n",
        "plt.figure(figsize=(10,10))\n",
        "\n",
        "ax = plt.subplot(111, polar=True)\n",
        "\n",
        "for idx in profile_scaled.index:\n",
        "\n",
        "    values = profile_scaled.loc[idx].tolist()\n",
        "    values += values[:1]\n",
        "\n",
        "    ax.plot(angles, values, linewidth=2, label=f'Cluster {idx}')\n",
        "    ax.fill(angles, values, alpha=0.08)\n",
        "\n",
        "ax.set_xticks(angles[:-1])\n",
        "ax.set_xticklabels(categories, fontsize=10)\n",
        "\n",
        "plt.title(\"Radar Chart of Cluster Characteristics\", fontsize=15)\n",
        "plt.legend(loc='upper right', bbox_to_anchor=(1.35,1.1))\n",
        "\n",
        "plt.show()"
      ],
